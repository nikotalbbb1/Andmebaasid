create trigger hobuseUuenda
on hobused
for update
as
insert into logi(kuupaev,andmed,kasutaja)
select 
getdate(), 
concat('vana hobuse andmed: ', d.nimi, ' | vanus: ', d.vanus, ' | kiirus: ', d.kiirus, 
' uued hobuse andmed: ', i.nimi, ' | vanus: ', i.vanus, ' | kiirus: ', i.kiirus),
SYSTEM_USER
from deleted d inner join inserted i 
on d.id=i.id;
