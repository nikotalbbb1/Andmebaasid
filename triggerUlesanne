create database hobusedDb
use hobusedDb

create table hobused(
id int primary key identity(1,1),
nimi varchar(25),
vanus int,
kiirus int);

create table logi(
id2 int primary key identity(1,1),
kuupaev datetime,
andmed text,
kasutaja varchar(30));

create trigger hobuseLisa
on hobused
for insert
as
insert into logi(kuupaev,andmed,kasutaja)
select 
getdate(),
concat('lisatud hobune: ', inserted.nimi, ' Hobuse vanus : ' , inserted.vanus, ' Hobuse kiirus : ' , inserted.kiirus),
SYSTEM_USER
from inserted;



